{
    "compilerOptions": {
      "target": "ES2022",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
  
      "rootDir": "src",
      "outDir": "dist",
  
      "strict": true,
      "skipLibCheck": true,
  
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "allowJs": true,
  
      "noImplicitAny": false
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}

